<Window x:Class="WpfApp2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Спортивный магазин - Управление товарами" 
        Height="700" Width="1000"
        WindowStartupLocation="CenterScreen">

    <Window.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FF1E3C72" Offset="0"/>
            <GradientStop Color="#FF2A5298" Offset="1"/>
        </LinearGradientBrush>
    </Window.Background>

    <Grid Margin="20">
        <Border Background="White" CornerRadius="10" Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <Ellipse Width="50" Height="50" Stroke="#1E3C72" StrokeThickness="2">
                            <Ellipse.Fill>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#FF4CAF50" Offset="0"/>
                                    <GradientStop Color="#FF2E7D32" Offset="1"/>
                                </LinearGradientBrush>
                            </Ellipse.Fill>
                        </Ellipse>
                        <TextBlock Text="SPORTS STORE" 
                                   FontSize="24" 
                                   FontWeight="Bold" 
                                   VerticalAlignment="Center"
                                   Margin="10,0,0,0"
                                   Foreground="#1E3C72"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <TextBlock x:Name="txtUserInfo" 
                                   VerticalAlignment="Center"
                                   FontSize="14"
                                   Foreground="#666"
                                   Margin="0,0,10,0"/>
                        <Button Content="Выйти" 
                                Height="35"
                                Width="100"
                                Background="#f44336"
                                Foreground="White"
                                BorderThickness="0"
                                Cursor="Hand"
                                Click="btnLogout_Click">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="5"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </StackPanel>
                </Grid>

                <Border Grid.Row="1" Background="#F5F5F5" CornerRadius="5" Padding="15" Margin="0,0,0,20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <Button Content="➕ Добавить товар" 
                                    Height="40" Width="130" Margin="0,0,10,0"
                                    Background="#4CAF50" Foreground="White"
                                    BorderThickness="0" Cursor="Hand"
                                    Click="btnAdd_Click"/>
                            <Button Content="✏️ Редактировать" 
                                    Height="40" Width="130" Margin="0,0,10,0"
                                    Background="#2196F3" Foreground="White"
                                    BorderThickness="0" Cursor="Hand"
                                    Click="btnEdit_Click"/>
                            <Button Content="🗑️ Удалить" 
                                    Height="40" Width="130"
                                    Background="#f44336" Foreground="White"
                                    BorderThickness="0" Cursor="Hand"
                                    Click="btnDelete_Click"/>
                        </StackPanel>

                        <TextBox x:Name="txtSearch" 
                                 Grid.Column="1" 
                                 Width="200" Height="35"
                                 Padding="10,5"
                                 TextChanged="txtSearch_TextChanged"/>
                    </Grid>
                </Border>

                <DataGrid x:Name="dgProducts" 
                          Grid.Row="2"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          Background="White"
                          RowHeight="40"
                          Margin="0,0,0,20"
                          MouseDoubleClick="dgProducts_MouseDoubleClick">

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                        <DataGridTextColumn Header="Наименование" Binding="{Binding Name}" Width="*"/>
                        <DataGridTextColumn Header="Категория" Binding="{Binding Category}" Width="120"/>
                        <DataGridTextColumn Header="Цена" Binding="{Binding Price, StringFormat=C}" Width="100"/>
                        <DataGridTextColumn Header="Количество" Binding="{Binding Quantity}" Width="100"/>
                        <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="100"/>
                        <DataGridTextColumn Header="Дата добавления" Binding="{Binding AddedDate, StringFormat=dd.MM.yyyy}" Width="120"/>
                    </DataGrid.Columns>
                </DataGrid>

                <Border Grid.Row="3" Background="#F5F5F5" CornerRadius="5" Padding="15">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Всего товаров: " Foreground="#666"/>
                        <TextBlock x:Name="txtTotalItems" Text="0" Foreground="#1E3C72" FontWeight="Bold"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>